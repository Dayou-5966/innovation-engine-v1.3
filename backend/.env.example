# ── The Innovation Engine — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Google Gemini API ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Auth & Security ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here_32_chars_minimum

# Generate a bcrypt hash of your password with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
ADMIN_HASH=your_bcrypt_hash_here

# Legacy plaintext fallback (used only if ADMIN_HASH is not set). Not recommended.
# ADMIN_SECRET=EUREKA

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default, local dev):
#   DATABASE_PATH=/path/to/innovation_engine.db
# PostgreSQL (production):
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_PATH=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Defaults to localhost dev ports.
# Example: https://your-app.railway.app,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# Requests per minute for evaluation and generation endpoints.
RATE_LIMIT_EVALUATE=5/minute
RATE_LIMIT_GENERATE=10/minute

# ── Multi-User ─────────────────────────────────────────────────────────────────
# Set to "true" to enable multi-user mode. Default: false (single admin user).
MULTI_USER_MODE=false
